# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_APP_URL=https://your-app.example.com
SHOPIFY_STORE_DOMAIN=e56aau-5f.myshopify.com
SCOPES=read_orders,read_products,read_analytics
NEXT_PUBLIC_SHOPIFY_API_KEY=
# Optional: set these when embedded App Bridge/session-token credentials differ
# from the Shopify Admin API token-refresh credentials above.
SHOPIFY_SESSION_API_KEY=
SHOPIFY_SESSION_API_SECRET=
NEXT_PUBLIC_SHOPIFY_SESSION_API_KEY=

# Database
# connection_limit caps Prisma's connection pool; pool_timeout fails fast when the pool is exhausted.
DATABASE_URL=postgresql://user:pass@host:5432/autopilot?connection_limit=10&pool_timeout=10
# Absolute server-only directory containing a complete six-artifact topical-map
# package plus manifest. Import and operator-triggered validation read only from
# this root; they never activate a version or write to Shopify or Meta. There is
# no topical-map validation cron.
TOPICAL_MAP_STRATEGY_ROOT=
# Server-only strategy-selection gate. This authorizes only the audited active
# topical-map pointer transition and is independent of Shopify/Meta live execution.
TOPICAL_MAP_ACTIVATION_ENABLED=false
# Optional: set true after production DATABASE_URL has the required pool settings.
DATABASE_URL_STRICT=false
# Durable DB-backed job queue.
JOB_QUEUE_DRAIN_LIMIT=1
JOB_QUEUE_HEARTBEAT_MS=30000
JOB_QUEUE_STALE_MINUTES=30
# Retention cleanup. Raw snapshots referenced by recommendations are retained
# even after this TTL because deleting them would delete recommendation history.
RAW_SNAPSHOT_RETENTION_DAYS=30
JOB_RUN_RETENTION_DAYS=90
# Live recommendation execution is opt-in. Cron defaults to dry-run.
EXECUTE_APPROVED_LIVE_ENABLED=false
# Optional alias accepted by the app/scripts when DATABASE_URL is not set.
DATABASE_URL_PROD=

# AI — DeepSeek is primary for skill runs; OpenRouter is fallback and still used by some legacy direct-analysis routes.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Meta Ads
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_AD_LIBRARY_ACCESS_TOKEN=
META_AD_LIBRARY_SCRAPE_ENABLED=false
# Optional: specific Facebook Page ID to fetch posts from. Falls back to first page in the account.
META_PAGE_ID=
# Optional: ISO date when the Meta access token expires. Shows a warning in connector health when within 30 days.
META_TOKEN_EXPIRES_AT=

# Keyword Planner API credentials (served through Google's Ads API; not paid campaign tracking)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Optional keyword research defaults: 2608 = Philippines, 1000 = English.
GOOGLE_ADS_KEYWORD_GEO_TARGET_ID=2608
GOOGLE_ADS_KEYWORD_LANGUAGE_ID=1000

# Google Analytics + Search Console (service accounts)
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON_PATH=
# Alternative for server envs where mounting a JSON file is inconvenient.
GA4_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=
GSC_SERVICE_ACCOUNT_JSON_PATH=
# Alternative for server envs where mounting a JSON file is inconvenient.
GSC_SERVICE_ACCOUNT_JSON=

# Klaviyo
KLAVIYO_API_KEY=

# Competitor Intelligence (Ryze scraper — local dev only)
# Point to the absolute path of scraper/data/index/ryze.db on your machine.
# Leave blank unless the local scraper database exists on this machine.
SCRAPER_DB_PATH=

# Market Intelligence
# Preferred provider for Google Shopping intelligence.
SERPER_API_KEY=
# Accepted aliases if an environment already uses one of these names.
SERPER_DEV_API_KEY=
SERPER_KEY=
GOOGLE_SERPER_API_KEY=
# Optional fallback provider for Google Shopping intelligence.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# DataForSEO Labs (ranked keywords + competitor keyword-gap). Metered API —
# OFF by default. Set to "true" to enable the fetch-market-intel step.
DATAFORSEO_LABS_ENABLED=false
# Max rows per Labs request (ranked keywords / domain intersection). Clamped
# to (0, 100]; default 20.
DATAFORSEO_LABS_LIMIT=20
# Labs-only Google database location (overrides MARKET_INTEL_DEFAULT_LOCATION
# for Labs calls only). Agriko's market is the Philippines — keep this on
# Philippines. Note: DataForSEO's PH Labs database may have thin coverage for
# small domains (probe 2026-07-03: 0 ranked keywords for agrikoph.com in PH).
DATAFORSEO_LABS_LOCATION=Philippines
# Our own domain for ranked-keyword lookups and keyword-gap comparisons.
MARKET_INTEL_OWN_DOMAIN=agrikoph.com
# Optional: use a separate Meta Ad Library token. Falls back to META_ACCESS_TOKEN if blank.
META_AD_LIBRARY_ACCESS_TOKEN=
MARKET_INTEL_ENABLED=true
MARKET_INTEL_KEYWORD_LIMIT=5
MARKET_INTEL_RESULTS_PER_KEYWORD=20
MARKET_INTEL_COMPETITOR_PAGE_LIMIT=10
MARKET_INTEL_ADS_PER_PAGE_LIMIT=50
MARKET_INTEL_DEFAULT_COUNTRY=PH
MARKET_INTEL_DEFAULT_LOCATION=Philippines
MARKET_INTEL_META_ACTIVE_STATUS=active
MARKET_INTEL_LONG_RUNNING_AD_DAYS=30

# Security
CREDENTIALS_ENCRYPTION_KEY=  # Generate: openssl rand -hex 32
CRON_SECRET=               # Generate: openssl rand -hex 32 (fails closed if absent)
ALERT_WEBHOOK_URL=         # Optional: POST sanitized JSON alerts (job failures, new recommendations, execution failures, guardrail hard-blocks, SLA escalations, daily digest). Point at a Slack/Discord/Telegram-bridge webhook.
ALERT_QUEUED_JOB_STALE_MINUTES=30
ALERT_RUNNING_JOB_STALE_MINUTES=30
ALERT_ACTIVE_JOB_LOCK_STALE_MINUTES=30
# Comma-separated Shopify session actors (`sub` values), or `*` for all authenticated app users.
# AUTOPILOT_ADMIN_ACTORS grants every permission below.
AUTOPILOT_ADMIN_ACTORS=
AUTOPILOT_SETTINGS_ADMIN_ACTORS=
AUTOPILOT_CONTENT_REVIEW_ACTORS=
AUTOPILOT_CONTENT_PUBLISH_ACTORS=
# Ad Approval workflow. SUBMIT = create/submit drafts. Review/approve authority
# is NOT env-gated: it comes from the reviewer assignment in Settings (the
# actor must match the assigned reviewer). ADMIN allows force-transition and
# acting on any approval.
AUTOPILOT_AD_APPROVAL_SUBMIT_ACTORS=
AUTOPILOT_AD_APPROVAL_ADMIN_ACTORS=
MARKET_INTEL_RESET_MAINTENANCE=true
MARKET_INTEL_RESET_MAINTENANCE_SECRET=
MARKET_INTEL_RESET_CONFIRMATION=
MARKET_INTEL_RESET_ALLOWED_SHOPS=
MARKET_INTEL_RESET_RATE_LIMIT_PER_MINUTE=3
EXECUTE_APPROVED_LIVE_ENABLED=false # Keep false until dry-run queue is clean and reviewed.

# Odysseus embedded workspace (required for /odysseus; baked in at build time)
NEXT_PUBLIC_ODYSSEUS_URL=https://odysseus.agrikoph.com
