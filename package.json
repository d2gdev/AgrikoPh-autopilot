{
  "name": "agriko-autopilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "node scripts/build-next.mjs",
    "build:local": "node scripts/build-next.mjs --local",
    "build:remote": "node scripts/build-next.mjs --remote",
    "build:clean": "node scripts/build-next.mjs --prisma=always",
    "start": "NODE_ENV=production node server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate && node scripts/check-prisma-client.mjs --write",
    "db:report": "node scripts/postgres-report.mjs",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "data:audit": "node scripts/data-layer-audit.mjs",
    "seo:enhance-articles": "node scripts/seo-enhance-articles.mjs",
    "seo:fix-meta": "node scripts/seo-fix-meta.mjs",
    "seo:brand-serp:capture": "tsx scripts/capture-brand-serp.ts",
    "seo:seed-tasks": "tsx scripts/seed-seo-follow-up-tasks.ts",
    "health:merchant": "node scripts/merchant-healthcheck.mjs",
    "data:duplicates": "node scripts/duplicate-ingestion-report.mjs",
    "data:dedupe": "node scripts/dedupe-dashboard-data.mjs",
    "dashboard:baseline": "node scripts/dashboard-baseline.mjs",
    "dashboard:baseline:remote": "node scripts/remote-dashboard-baseline.mjs",
    "jobs:stale": "node scripts/stale-job-runs.mjs",
    "shopify:token": "node scripts/refresh-shopify-admin-token.mjs",
    "shopify:refresh-token": "node scripts/refresh-shopify-admin-token.mjs",
    "shopify:check-token": "node scripts/refresh-shopify-admin-token.mjs --check-only",
    "store-tasks:cleanup-topical-map-advisories": "tsx scripts/cleanup-topical-map-advisories.ts",
    "codex:surface-loop": "node scripts/codex-surface-loop.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "verify:storefront-security-headers": "node scripts/verify-storefront-security-headers.mjs",
    "verify:prisma-client": "node scripts/check-prisma-client.mjs",
    "test:postgres": "DATABASE_URL=\"$DATABASE_URL_TEST\" prisma migrate deploy && DATABASE_URL=\"$DATABASE_URL_TEST\" vitest run --config vitest.postgres.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-api": "^13.0.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.6.1",
    "google-ads-api": "^24.1.0",
    "google-auth-library": "^10.9.0",
    "js-yaml": "^5.2.0",
    "next": "^15.5.19",
    "node-html-parser": "^7.1.0",
    "openai": "^4.0.0",
    "p-limit": "^7.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "jsdom": "^29.1.1",
    "playwright": "^1.49.0",
    "prisma": "^6.19.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "postcss": "^8.5.15",
    "uuid": "^11.1.1",
    "google-auth-library": "^10.9.0"
  }
}
