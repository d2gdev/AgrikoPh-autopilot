{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "action",
    "reason",
    "requires_approval",
    "approval_scope",
    "next_prompt",
    "question",
    "current_task_id",
    "completed_task_ids"
  ],
  "properties": {
    "action": { "enum": ["run", "ask_user", "done"] },
    "reason": { "type": "string", "minLength": 1 },
    "requires_approval": { "type": "boolean" },
    "approval_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_prompt": { "type": ["string", "null"] },
    "question": { "type": ["string", "null"] },
    "current_task_id": { "type": ["string", "null"] },
    "completed_task_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
