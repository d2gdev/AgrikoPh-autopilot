{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "outcome",
    "approval_required",
    "approval_question",
    "blockers",
    "recommended_next_step",
    "runtime_impact",
    "audit_pass"
  ],
  "properties": {
    "status": { "enum": ["complete", "blocked", "failed"] },
    "outcome": { "type": "string", "minLength": 1 },
    "approval_required": { "type": "boolean" },
    "approval_question": { "type": ["string", "null"] },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_next_step": { "type": ["string", "null"] },
    "audit_pass": {
      "type": ["object", "null"],
      "required": ["clean", "defects", "fixes", "verification"],
      "properties": {
        "clean": { "type": "boolean" },
        "defects": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "fixes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "verification": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "runtime_impact": {
      "type": "object",
      "required": ["production_accessed", "deployed", "live_changes_made"],
      "properties": {
        "production_accessed": { "type": "boolean" },
        "deployed": { "type": "boolean" },
        "live_changes_made": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
